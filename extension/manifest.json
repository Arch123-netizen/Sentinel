{
    "manifest_version": 3,
    "name": "Sentinel", 
    "version": "1.0.0",
    "description": "AI-assisted Phishing Detection Browser Extension.",
    "action":{
        "default_popup": "popup/popup.html"
    },
    "background": {
        "service_worker": "scripts/background.js"
    },
    "permissions": [
        "activeTab",
        "tabs"
    ]
}